# ============================================
# Blog 生产环境配置
# 复制此文件为 .env 并修改下面的值
# ============================================

# 【必填】密钥 - 用 openssl rand -hex 32 生成
SECRET_KEY=change-me-to-a-random-string

# 【必填】你的域名（已备案）
CORS_ORIGINS=http://你的域名.com

# 前端 API 地址（Nginx 代理，保持默认即可）
VITE_API_BASE_URL=/api/v1

# 前端对外端口
FRONTEND_PORT=80

# 数据库（SQLite 先用着）
DATABASE_URL=sqlite:////app/data/blog.db

# 环境模式
ENVIRONMENT=production
DEBUG=false

# 禁止自动创建默认管理员（安全）
CREATE_DEFAULT_ADMIN=false
